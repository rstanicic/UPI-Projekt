<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Članarina"
        app:titleTextColor="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STATUS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_status_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_status_tekst"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_plan_naziv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_gray"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_dana_ostalo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_gray"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ODABIR PLANA (vlastiti + admin) -->
            <LinearLayout
                android:id="@+id/layout_planovi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Odaberi plan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_plan_mjesecna"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_mj_naziv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mj."
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>

                            <TextView
                                android:id="@+id/tv_mj_cijena"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10€"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <TextView
                                android:id="@+id/tv_mj_opis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30 dana"
                                android:textSize="11sp"
                                android:textColor="@color/text_gray"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_plan_polugodisnja"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_pol_naziv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pol."
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>

                            <TextView
                                android:id="@+id/tv_pol_cijena"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="55€"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <TextView
                                android:id="@+id/tv_pol_opis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6 mj."
                                android:textSize="11sp"
                                android:textColor="@color/text_gray"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_plan_godisnja"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_god_naziv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="God."
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>

                            <TextView
                                android:id="@+id/tv_god_cijena"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100€"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <TextView
                                android:id="@+id/tv_god_opis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12 mj."
                                android:textSize="11sp"
                                android:textColor="@color/text_gray"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>

            <!-- DETALJI (vlastiti + admin) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detalji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detalji"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tv_iznos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tv_datum_uplate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tv_datum_isteka"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tv_nacin_placanja"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ADMIN: Ručno uređivanje -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️ Admin — ručno uređivanje"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Način plaćanja"
                        android:textSize="13sp"
                        android:textColor="@color/text_gray"
                        android:layout_marginBottom="4dp"/>

                    <Spinner
                        android:id="@+id/spinner_nacin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Datum uplate (DD.MM.GGGG)"
                        android:layout_marginBottom="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_admin_datum_uplate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Datum isteka (DD.MM.GGGG)"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_admin_datum_isteka"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_admin_spremi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Spremi ručne izmjene"
                        android:backgroundTint="@color/primary"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- NAČIN PLAĆANJA (vlastiti + admin) -->
            <LinearLayout
                android:id="@+id/layout_nacin_placanja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Način plaćanja"
                    android:textSize="14sp"
                    android:textColor="@color/text_gray"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinner_nacin_member"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- AKCIJSKI GUMBI -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_plati"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="💳 Plati / Obnovi članarinu"
                android:textSize="16sp"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="8dp"
                app:cornerRadius="16dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ponisti"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Poništi uplatu"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
